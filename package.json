{
  "name": "cem-monorepo",
  "version": "1.2.0",
  "private": true,
  "description": "Claude Environment Manager (CEM) — backup, restore, manage and migrate Claude Code environments.",
  "type": "module",
  "license": "MIT",
  "author": "Luiz Dione and CEM Contributors",
  "homepage": "https://github.com/luizdione/CEM",
  "repository": {
    "type": "git",
    "url": "https://github.com/luizdione/CEM.git"
  },
  "bugs": {
    "url": "https://github.com/luizdione/CEM/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build && pnpm --filter @cem/cli build",
    "build:packages": "pnpm -r --filter \"./packages/*\" build",
    "build:cli": "pnpm --filter @cem/cli build",
    "build:desktop": "pnpm --filter @cem/desktop build",
    "dev:cli": "pnpm --filter @cem/cli dev",
    "dev:desktop": "pnpm --filter @cem/desktop dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "typecheck": "tsc -p tsconfig.json",
    "clean": "pnpm -r exec rm -rf dist node_modules/.cache && rm -rf node_modules",
    "cli": "pnpm --filter @cem/cli exec node dist/index.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
