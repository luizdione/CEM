{
  "name": "@cem/desktop",
  "version": "1.3.0",
  "description": "Claude Environment Manager desktop application (Electron + React).",
  "type": "module",
  "license": "MIT",
  "main": "./out/main/index.js",
  "author": "Luiz Dione and CEM Contributors",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "package": "electron-vite build && electron-builder",
    "package:linux": "electron-vite build && electron-builder --linux",
    "package:win": "electron-vite build && electron-builder --win",
    "package:mac": "electron-vite build && electron-builder --mac",
    "clean": "rm -rf out dist-electron release"
  },
  "dependencies": {
    "@cem/backup": "workspace:*",
    "@cem/core": "workspace:*",
    "@cem/crypto": "workspace:*",
    "@cem/diagnostics": "workspace:*",
    "@cem/markdown": "workspace:*",
    "@cem/mcp": "workspace:*",
    "@cem/profiles": "workspace:*",
    "@cem/restore": "workspace:*",
    "@cem/scanner": "workspace:*",
    "@cem/shared": "workspace:*",
    "@cem/sync": "workspace:*",
    "@cem/usage": "workspace:*",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.3",
    "vite": "^5.4.11"
  }
}
