{
  "name": "@cem/backup",
  "version": "1.1.0",
  "description": "Backup engine for CEM: plans artifacts into the .cem archive format with checksums and optional encryption.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@cem/shared": "workspace:*",
    "@cem/core": "workspace:*",
    "@cem/crypto": "workspace:*",
    "@cem/scanner": "workspace:*",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
